{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://snapurl-xqf0.onrender.com/api/:path*"
    },
    {
      "source": "/:code([a-zA-Z0-9]{1,10})",
      "destination": "https://snapurl-xqf0.onrender.com/:code"
    },
    {
      "source": "/((?!api/|assets/|static/).*)",
      "destination": "/index.html"
    }
  ]
}
